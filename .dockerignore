# Next.js build output (re-generated inside the container)
.next/
out/

# Dependencies (re-installed inside the container)
node_modules/

# Environment files — never bake secrets into the image
.env
.env.*

# Version control
.git/
.gitignore
.github/

# IDE / editor config
.vscode/
.idea/
.windsurf/

# Test artefacts
coverage/
test-results/
playwright-report/
tests/
e2e/
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# Development-only tooling
docs/
_bmad/
_bmad-output/
scripts/

# Miscellaneous
*.md
*.log
*.pem
.DS_Store
Thumbs.db
