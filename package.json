{
  "name": "forkast",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "quality-check": "npm run lint && npm run type-check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:api": "node scripts/test-api.js",
    "test:shopping-aggregate": "tsx scripts/test-shopping-aggregate.ts",
    "test:shopping-list:api": "node scripts/test-shopping-list-api.js",
    "test:shopping-list-api": "npm run test:shopping-list:api",
    "diagnostic": "node -e \"console.log('npm script execution works')\"",
    "seed:meals": "dotenv -e .env.local -- tsx scripts/seed-test-meals.ts",
    "update:meal-types": "dotenv -e .env.local -- tsx scripts/update-meal-types.ts",
    "update:last-prepared": "dotenv -e .env.local -- tsx scripts/update-last-prepared-dates.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@sentry/nextjs": "^10.17.0",
    "@stripe/stripe-js": "^8.0.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.4",
    "@tanstack/react-query": "^5.84.1",
    "@types/swagger-ui-react": "^5.18.0",
    "cheerio": "^1.0.0-rc.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "geist": "^1.4.2",
    "lucide-react": "^0.525.0",
    "next": "^14.2.3",
    "next-swagger-doc": "^0.4.1",
    "next-themes": "^0.4.6",
    "react": "^18",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18",
    "react-hook-form": "^7.51.0",
    "sonner": "^2.0.6",
    "stripe": "^19.1.0",
    "swagger-ui-react": "^5.27.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.43.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^4.1.4",
    "cross-env": "^10.0.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^10.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.3",
    "globals": "^16.3.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.6.2",
    "supabase": "^2.98.2",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
