# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
claude.md
.vibeyardignore
.mcp.json
1

# Project documentation (not needed at runtime)
QA_GUIDELINES.md
DOCKER_DEPLOY.md
EDGE_FUNCTION_DEPLOY.md
README.md
tmp-extract.mjs

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Build outputs
build/
dist/
out/
target/

# e2e auth state (Playwright sessions — never commit)
e2e/.auth/

# Temporary files
*.tmp
*.temp
*.cache
*.bak
*.tar

# Log files
*.log
logs/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Exclude entire directories (note the trailing slash)
build/
dist/
node_modules/
temp/
.bmad-coverage/
.windsurf/
docs/
web-bundles/
.agent/
.agents/
.zencoder/
_bmad/
_bmad-output/
test-results/
.claude/
.vscode/
.switchboard/
.next/
.ruff_cache/
.swc/
coverage/
playwright-report/
scripts/

# Generated reports
eslint-report.*
repomix-output.*
test-results.json

# Lock files (using npm)
yarn.lock

# Exclude all contents of a directory but keep the directory structure
build/*
.pi-orchestrator/
.pi/npm/
