# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
claude.md
.vibeyardignore

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Build outputs
build/
dist/
out/
target/

# e2e auth state (Playwright sessions — never commit)
e2e/.auth/

# Temporary files
*.tmp
*.temp
*.cache
*.bak

# Log files
*.log
logs/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Exclude entire directories (note the trailing slash)
build/
dist/
node_modules/
temp/
.bmad-coverage/
.windsurf/
docs/
!docs/stories/
!docs/architecture/
web-bundles/
.agent/
_bmad/

# Generated reports
eslint-report.*
repomix-output.*

# Lock files (using npm)
yarn.lock

# Exclude all contents of a directory but keep the directory structure
build/*
